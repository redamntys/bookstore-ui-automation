<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="SmokeTestSuite" verbose="2" parallel="tests" thread-count="1">
    <listeners>
        <listener class-name="com.dibimbing.core.TestListener"/>
        <listener class-name="com.dibimbing.core.RetryListener"/>
    </listeners>
    <parameter name="browser" value="chrome"/>
    <test name="BookstoreLoginTests">
        <groups>
            <run>
                <include name="smoke"/>
                <exclude name="p2"/>
            </run>
        </groups>
        <classes>
            <class name="com.dibimbing.bookstore.LoginTests"/>
        </classes>
    </test>
    <test name="BookstoreHomePageTests">
       <groups>
           <run>
               <include name="smoke"/>
               <exclude name="p2"/>
           </run>
       </groups>
       <classes>
           <class name="com.dibimbing.bookstore.HomePageTests"/>
       </classes>
   </test>
   <test name="SaucedemoLoginTests">
       <groups>
           <run>
               <include name="smoke"/>
           </run>
       </groups>
       <classes>
           <class name="com.dibimbing.saucedemo.LoginTests"/>
       </classes>
   </test>
</suite>
