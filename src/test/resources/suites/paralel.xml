<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="ParallelTestSuite" verbose="1" parallel="classes" thread-count="3">
    <listeners>
        <listener class-name="com.dibimbing.core.TestListener"/>
        <listener class-name="com.dibimbing.core.RetryListener"/>
    </listeners>
    <parameter name="browser" value="chrome"/>
    <test name="AllTests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.dibimbing.bookstore.LoginTests"/>
            <class name="com.dibimbing.bookstore.HomePageTests"/>
            <class name="com.dibimbing.saucedemo.LoginTests"/>
        </classes>
    </test>
</suite>
